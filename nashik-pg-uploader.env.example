# ╔══════════════════════════════════════════════════════════════════╗
# ║  Nashik PG — Drive to YouTube Uploader Configuration           ║
# ║  Copy to nashik-pg-uploader.env and fill in real values.       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Google Drive ──────────────────────────────────────────────────
DRIVE_FOLDER_ID=your_google_drive_folder_id

# ── Gemini API Keys (rotated automatically; add as many as needed) ──
GEMINI_API_KEY=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3

# ── OAuth Credential Files ────────────────────────────────────────
DRIVE_CREDENTIALS_FILE="/home/anonsid/project/YOUTUBE AUTOMATION/DriveOAuth.json"
YOUTUBE_CREDENTIALS_FILE="/home/anonsid/project/YOUTUBE AUTOMATION/YoutubeOAuth.json"
DRIVE_TOKEN_FILE="/home/anonsid/project/YOUTUBE AUTOMATION/token-drive.json"
YOUTUBE_TOKEN_FILE="/home/anonsid/project/YOUTUBE AUTOMATION/token-youtube.json"
UPLOADED_LOG="/home/anonsid/project/YOUTUBE AUTOMATION/uploaded.txt"

# ── Polling & API Settings ────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
API_MAX_RETRIES=3

# ── YouTube Upload Settings ───────────────────────────────────────
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=22
YOUTUBE_NOTIFY_SUBSCRIBERS=true
YOUTUBE_UPLOAD_CHUNK_SIZE=-1
YOUTUBE_UPLOAD_MAX_RETRIES=5

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/home/anonsid/project/YOUTUBE AUTOMATION/nashik-pg-uploader.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# ── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_NOTIFY_POLL_SECONDS=5
DASHBOARD_URL=http://127.0.0.1:5052
